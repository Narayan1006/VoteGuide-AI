# ============================================================
# VoteGuide AI — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# Google Gemini API (https://aistudio.google.com/app/apikey)
VITE_GEMINI_API_KEY=

# Google Maps JavaScript API (https://console.cloud.google.com/apis/credentials)
# Enable: Maps JavaScript API, Places API, Geocoding API
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Firebase Configuration (https://console.firebase.google.com)
# Project Settings > Your apps > Firebase SDK snippet > Config
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
VITE_FIREBASE_APP_ID=your_firebase_app_id_here
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# App Config
VITE_APP_NAME=VoteGuide AI
VITE_APP_VERSION=1.0.0
VITE_GEMINI_RATE_LIMIT=20
