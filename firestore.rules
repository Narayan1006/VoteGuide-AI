rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Quiz scores: only authenticated user can read/write their own
    match /quizScores/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Leaderboard: all authenticated users can read, only owner writes
    match /leaderboard/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Chat history: only authenticated user can read/write their own
    match /conversations/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // User profiles: only owner can read/write
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
