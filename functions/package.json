{
  "name": "voteguide-ai-functions",
  "description": "Firebase Cloud Functions for VoteGuide AI — Gemini API proxy with rate limiting",
  "scripts": {
    "lint": "eslint --ext .js,.ts .",
    "build": "echo 'No build step needed for JS functions'",
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "18"
  },
  "main": "index.js",
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^4.9.0",
    "@google/generative-ai": "^0.24.1",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "eslint": "^8.15.0",
    "eslint-config-google": "^0.14.0"
  },
  "private": true
}
